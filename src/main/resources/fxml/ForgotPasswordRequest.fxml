<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chrionline.ui.controller.ForgotPasswordRequestController"
      styleClass="split-pane-root">

    <!-- LEFT SIDE: Form -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="left-pane" maxWidth="640" minWidth="480">
        <VBox spacing="22" maxWidth="500" prefWidth="500">

            <!-- Logo area -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <ImageView fitWidth="52" fitHeight="52" preserveRatio="true" styleClass="app-logo-image">
                    <image>
                        <Image url="@/images/ChriOnline_logo.png"/>
                    </image>
                </ImageView>
                <Label text="ChriOnline" styleClass="brand-title-small"/>
            </HBox>

            <Region prefHeight="20" />

            <!-- Heading -->
            <VBox spacing="8" maxWidth="420">
                <Label text="Forgot your password?" styleClass="page-title"/>
                <Label text="Enter your email address and we'll send you a reset code" styleClass="brand-subtitle"/>
            </VBox>

            <Region prefHeight="10" />

            <!-- EMAIL -->
            <VBox spacing="8" maxWidth="420">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-envelope" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Email address" styleClass="field-label"/>
                </HBox>
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="auth-field" maxWidth="Infinity"/>
                <Label fx:id="emailError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- ERROR -->
            <Label fx:id="globalError" styleClass="global-error" wrapText="true" visible="false" managed="false"/>

            <!-- ACTION BUTTONS -->
            <VBox spacing="14">
                <Button fx:id="sendButton" text="Send Reset Email  →" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleSendResetEmail"/>

                <HBox alignment="CENTER">
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" styleClass="loading-spinner" prefWidth="38" prefHeight="38"/>
                </HBox>
            </VBox>

            <!-- BACK TO LOGIN -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Remember your password?" styleClass="link-text"/>
                <Hyperlink text="Sign In" styleClass="link-action" onAction="#goToLogin"/>
            </HBox>

            <!-- GO TO RESET -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Already have a reset token?" styleClass="link-text"/>
                <Hyperlink text="Reset Password" styleClass="link-action" onAction="#goToResetPassword"/>
            </HBox>

        </VBox>
    </VBox>

    <!-- RIGHT SIDE: Hero Panel -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="right-pane" minWidth="420">
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 60px 50px;">

            <!-- Feature icons row -->
            <HBox alignment="CENTER" spacing="32">
                <VBox alignment="CENTER" spacing="8">
                    <FontIcon iconLiteral="fas-envelope" iconSize="48" styleClass="feature-icon"/>
                    <Label text="Secure Recovery" styleClass="feature-title"/>
                    <Label text="Receive a secure reset link in your email" styleClass="feature-subtitle" textAlignment="CENTER"/>
                </VBox>
            </HBox>

        </VBox>
    </VBox>

</HBox>