<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chrionline.ui.controller.LoginController"
      styleClass="split-pane-root">

    <!-- LEFT SIDE: Form -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="left-pane" maxWidth="640" minWidth="560">
        <VBox spacing="22" maxWidth="400" prefWidth="400" minWidth="400" alignment="CENTER">

            <!-- Logo area -->
            <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="400">
                <ImageView fitWidth="52" fitHeight="52" preserveRatio="true" styleClass="app-logo-image">
                    <image>
                        <Image url="@/images/ChriOnline_logo.png"/>
                    </image>
                </ImageView>
                <Label text="ChriOnline" styleClass="brand-title-small"/>
            </HBox>

            <Region prefHeight="20" />

            <!-- Heading -->
            <VBox spacing="8" maxWidth="400" prefWidth="400" minWidth="400">
                <Label text="Welcome back 👋" styleClass="page-title"/>
                <Label text="Sign in to your account to continue shopping" styleClass="brand-subtitle"/>
            </VBox>

            <Region prefHeight="10" />

            <!-- EMAIL -->
            <VBox spacing="8" maxWidth="400" prefWidth="400" minWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-envelope" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Email address" styleClass="field-label"/>
                </HBox>
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="auth-field" maxWidth="400" prefWidth="400" minWidth="400"/>
                <Label fx:id="emailError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- PASSWORD -->
            <VBox spacing="8" maxWidth="400" prefWidth="400" minWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-lock" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Password" styleClass="field-label"/>
                </HBox>
                <StackPane alignment="CENTER_RIGHT" maxWidth="400" prefWidth="400" minWidth="400">
                    <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="auth-field" maxWidth="400" prefWidth="400" minWidth="400"/>
                    <TextField fx:id="passwordTextField" promptText="••••••••" styleClass="auth-field" visible="false" maxWidth="400" prefWidth="400" minWidth="400"/>
                    <Button fx:id="togglePasswordButton" styleClass="eye-button" onAction="#togglePasswordVisibility" focusTraversable="false">
                        <graphic>
                            <FontIcon fx:id="togglePasswordIcon" iconLiteral="fas-eye-slash" iconSize="14" styleClass="ikonli-muted"/>
                        </graphic>
                    </Button>
                </StackPane>
                <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- ERROR -->
            <Label fx:id="globalError" styleClass="global-error" wrapText="true" visible="false" managed="false" maxWidth="400" prefWidth="400" minWidth="400" alignment="CENTER"/>

            <VBox fx:id="recaptchaBox" spacing="6" visible="false" managed="false" maxWidth="400" prefWidth="400" minWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-shield-alt" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Security check" styleClass="field-label"/>
                </HBox>
                <StackPane fx:id="recaptchaContainer" styleClass="recaptcha-panel" maxWidth="400" prefWidth="400" minWidth="400"/>
                <Label fx:id="recaptchaHintLabel" styleClass="info-box-text" visible="false" managed="false" alignment="CENTER" maxWidth="400" prefWidth="400" minWidth="400"/>
            </VBox>

            <!-- ACTION BUTTONS -->
            <VBox spacing="14" maxWidth="400" prefWidth="400" minWidth="400">
                <HBox alignment="CENTER_RIGHT">
                    <Hyperlink text="Forgot password?" styleClass="link-action-small" onAction="#handleForgotPassword"/>
                </HBox>

                <Button fx:id="loginButton" text="Sign In  →" styleClass="btn-primary" maxWidth="400" prefWidth="400" minWidth="400" onAction="#handleLogin"/>

                <HBox alignment="CENTER">
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" styleClass="loading-spinner" prefWidth="38" prefHeight="38"/>
                </HBox>
            </VBox>

            <!-- CREATE ACCOUNT -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?" styleClass="link-text"/>
                <Hyperlink text="Create one" styleClass="link-action" onAction="#goToRegister"/>
            </HBox>

        </VBox>
    </VBox>

    <!-- RIGHT SIDE: Hero Panel -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="right-pane" minWidth="420">
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 60px 50px;">

            <!-- Feature icons row -->
            <HBox alignment="CENTER" spacing="32">
                <VBox alignment="CENTER" spacing="8">
                    <StackPane style="-fx-background-color: rgba(244,106,61,0.2); -fx-background-radius: 50%; -fx-padding: 18px;">
                        <FontIcon iconLiteral="fas-shopping-bag" iconSize="28" styleClass="ikonli-accent"/>
                    </StackPane>
                    <Label text="Shop" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="8">
                    <StackPane style="-fx-background-color: rgba(192,132,252,0.2); -fx-background-radius: 50%; -fx-padding: 18px;">
                        <FontIcon iconLiteral="fas-shield-alt" iconSize="28" styleClass="ikonli-purple"/>
                    </StackPane>
                    <Label text="Secure" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="8">
                    <StackPane style="-fx-background-color: rgba(34,197,94,0.2); -fx-background-radius: 50%; -fx-padding: 18px;">
                        <FontIcon iconLiteral="fas-truck" iconSize="28" styleClass="ikonli-green"/>
                    </StackPane>
                    <Label text="Fast" style="-fx-text-fill: #475569; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <Label text="Shop smarter.&#10;Live better." styleClass="hero-title" textAlignment="CENTER"/>

            <Label text="Discover curated products from the world's&#10;best brands, all in one place." styleClass="hero-subtitle" textAlignment="CENTER"/>

            <!-- Stats row -->
            <HBox alignment="CENTER" spacing="40" style="-fx-padding: 10px 0 0 0;">
                <VBox alignment="CENTER" spacing="4">
                    <Label text="50K+" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #fb923c;"/>
                    <Label text="Products" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </VBox>
                <Region style="-fx-background-color: rgba(15,23,42,0.12); -fx-pref-width: 1px; -fx-pref-height: 40px;"/>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="10K+" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #c084fc;"/>
                    <Label text="Customers" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </VBox>
                <Region style="-fx-background-color: rgba(15,23,42,0.12); -fx-pref-width: 1px; -fx-pref-height: 40px;"/>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="99%" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #86efac;"/>
                    <Label text="Satisfaction" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>
        </VBox>
    </VBox>

</HBox>
