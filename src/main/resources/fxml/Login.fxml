<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.chrionline.ui.controller.LoginController"
           styleClass="root-pane">

    <!-- Fond dégradé (appliqué via CSS sur .root-pane) -->

    <!-- Carte de connexion centrée -->
    <VBox styleClass="auth-card" maxWidth="480" maxHeight="620" alignment="CENTER">
        <padding><Insets top="56" right="56" bottom="56" left="56"/></padding>
        <spacing>0</spacing>

        <!-- Logo / Titre -->
        <VBox alignment="CENTER" spacing="8">
            <Label text="ChriOnline" styleClass="brand-title"/>
            <Label text="Connectez-vous à votre compte" styleClass="brand-subtitle"/>
        </VBox>

        <Region prefHeight="40"/>

        <!-- Champ Email -->
        <VBox spacing="8">
            <Label text="Adresse email" styleClass="field-label"/>
            <TextField fx:id="emailField"
                       promptText="exemple@email.com"
                       styleClass="auth-field"/>
            <Label fx:id="emailError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="20"/>

        <!-- Champ Mot de passe -->
        <VBox spacing="8">
            <Label text="Mot de passe" styleClass="field-label"/>
            <StackPane alignment="CENTER_RIGHT">
                <PasswordField fx:id="passwordField" promptText="Minimum 8 caractères" styleClass="auth-field"/>
                <TextField fx:id="passwordTextField" promptText="Minimum 8 caractères" styleClass="auth-field" visible="false"/>
                <Button fx:id="togglePasswordButton" text="👁" styleClass="eye-button" onAction="#togglePasswordVisibility" focusTraversable="false" />
            </StackPane>
            <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="12"/>

        <!-- Message d'erreur global (serveur) -->
        <Label fx:id="globalError"
               styleClass="global-error"
               wrapText="true"
               visible="false"
               managed="false"/>

        <Region prefHeight="32"/>

        <!-- Bouton Se connecter -->
        <Button fx:id="loginButton"
                text="Se connecter"
                styleClass="btn-primary"
                maxWidth="Infinity"
                onAction="#handleLogin"/>

        <Region prefHeight="24"/>

        <!-- Lien vers inscription -->
        <HBox alignment="CENTER" spacing="8">
            <Label text="Pas encore de compte ?" styleClass="link-text"/>
            <Hyperlink text="Créer un compte"
                       styleClass="link-action"
                       onAction="#goToRegister"/>
        </HBox>

        <!-- Indicateur de chargement -->
        <ProgressIndicator fx:id="loadingIndicator"
                           visible="false"
                           managed="false"
                           styleClass="loading-spinner"
                           prefWidth="36"
                           prefHeight="36"/>
        <VBox.margin>
            <Insets top="12"/>
        </VBox.margin>

    </VBox>
</StackPane>
