<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.chrionline.ui.controller.ProductDetailController"
           styleClass="root-pane">

    <ScrollPane fitToWidth="true" styleClass="content-scroll" StackPane.alignment="TOP_LEFT">
        <content>
            <VBox spacing="0" style="-fx-background-color: transparent;">

                <HBox alignment="CENTER" styleClass="navbar" prefHeight="84">
                    <HBox alignment="CENTER_LEFT" spacing="18" maxWidth="1380" HBox.hgrow="ALWAYS" style="-fx-padding: 0 28px;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <ImageView fitWidth="46" fitHeight="46" preserveRatio="true" styleClass="app-logo-image">
                                <image>
                                    <Image url="@/images/ChriOnline_logo.png"/>
                                </image>
                            </ImageView>
                            <Label text="ChriOnline" styleClass="brand-title-small"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox alignment="CENTER" spacing="18">
                            <Button fx:id="navHomeBtn" onAction="#handleOpenHome" styleClass="nav-pill">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-home" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Accueil" styleClass="nav-pill-text"/>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="navCatalogueBtn" onAction="#handleOpenCatalogue" styleClass="nav-pill">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-th-large" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Catalogue" styleClass="nav-pill-text"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>

                        <Region minWidth="16"/>

                        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                            <TextField fx:id="headerSearchField"
                                       promptText="Cherchez un produit, une marque ou une categorie"
                                       onAction="#handleHeaderSearch"
                                       styleClass="search-bar header-search-field"
                                       HBox.hgrow="ALWAYS"/>
                            <Button onAction="#handleHeaderSearch" styleClass="header-search-button">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="ikonli-on-primary"/>
                                        <Label text="Rechercher" styleClass="header-search-button-text"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="nav-actions">
                            <MenuButton fx:id="accountMenuButton" text="Bonjour, Utilisateur" styleClass="nav-pill account-menu">
                                <graphic>
                                    <FontIcon iconLiteral="fas-user-circle" iconSize="16" styleClass="ikonli-muted"/>
                                </graphic>
                                <items>
                                    <MenuItem fx:id="accountProfileItem" text="Votre compte"/>
                                    <MenuItem fx:id="accountOrdersItem" text="Vos commandes"/>
                                    <MenuItem fx:id="accountAdminItem" text="Admin"/>
                                    <MenuItem fx:id="accountLogoutItem" text="Deconnexion"/>
                                </items>
                            </MenuButton>
                            <Button fx:id="bellButton" onAction="#toggleNotifications" styleClass="nav-pill nav-pill-icon">
                                <graphic>
                                    <StackPane>
                                        <FontIcon iconLiteral="fas-bell" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label fx:id="unreadBadge" text="0"
                                               visible="false" managed="false"
                                               styleClass="badge-unread"
                                               StackPane.alignment="TOP_RIGHT"/>
                                    </StackPane>
                                </graphic>
                            </Button>
                            <Button onAction="#handleOpenCart" styleClass="nav-pill">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-shopping-cart" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Panier" style="-fx-text-fill: #334155; -fx-font-weight: 700;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="adminButton" onAction="#handleOpenAdmin" styleClass="btn-outline" visible="false" managed="false">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="6">
                                        <FontIcon iconLiteral="fas-user-shield" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Admin" style="-fx-text-fill: #64748b; -fx-font-weight: 600;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>
                    </HBox>
                </HBox>

                <VBox alignment="TOP_CENTER" style="-fx-padding: 42px 40px 72px 40px;">
                    <VBox maxWidth="1200" spacing="26" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button onAction="#handleBackToCatalog" styleClass="btn-outline">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-arrow-left" iconSize="12" styleClass="ikonli-muted"/>
                                        <Label text="Retour au catalogue" style="-fx-text-fill: #64748b; -fx-font-weight: 600;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>

                        <HBox spacing="34" alignment="TOP_LEFT">
                            <VBox spacing="18" HBox.hgrow="ALWAYS" maxWidth="540">
                                <StackPane styleClass="product-media detail-main-media" prefHeight="460" minHeight="360" maxWidth="Infinity">
                                    <ImageView fx:id="productImageView" fitWidth="460" fitHeight="420" preserveRatio="true" smooth="true"/>
                                    <HBox alignment="CENTER" spacing="0" maxWidth="Infinity" StackPane.alignment="CENTER">
                                        <Button fx:id="prevImageButton" onAction="#handleShowPreviousImage" styleClass="nav-pill nav-pill-icon"
                                                style="-fx-background-color: rgba(255,255,255,0.92); -fx-border-color: rgba(148,163,184,0.28);"
                                                HBox.hgrow="NEVER">
                                            <graphic>
                                                <FontIcon iconLiteral="fas-chevron-left" iconSize="14" styleClass="ikonli-muted"/>
                                            </graphic>
                                        </Button>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="nextImageButton" onAction="#handleShowNextImage" styleClass="nav-pill nav-pill-icon"
                                                style="-fx-background-color: rgba(255,255,255,0.92); -fx-border-color: rgba(148,163,184,0.28);"
                                                HBox.hgrow="NEVER">
                                            <graphic>
                                                <FontIcon iconLiteral="fas-chevron-right" iconSize="14" styleClass="ikonli-muted"/>
                                            </graphic>
                                        </Button>
                                    </HBox>
                                    <VBox fx:id="imagePlaceholderBox" alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-image" iconSize="40" styleClass="ikonli-dim"/>
                                        <Label fx:id="imagePlaceholderLabel" text="Aucune image disponible" styleClass="image-placeholder"/>
                                    </VBox>
                                </StackPane>

                                <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="content-scroll" prefViewportHeight="108">
                                    <content>
                                        <FlowPane fx:id="galleryPane" hgap="12" vgap="12" prefWrapLength="600" alignment="CENTER"/>
                                    </content>
                                </ScrollPane>
                            </VBox>

                            <VBox spacing="18" HBox.hgrow="ALWAYS" maxWidth="520">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <Label fx:id="productCategoryLabel" text="Categorie" styleClass="product-category"/>
                                    <Label fx:id="stockStatusLabel" text="En stock" styleClass="badge-instock"/>
                                </HBox>

                                <Label fx:id="productNameLabel" text="Nom du Produit" styleClass="product-detail-title" wrapText="true"/>

                                <Label fx:id="productPriceLabel" text="0.00 Dhs" styleClass="product-detail-price"/>

                                <Label fx:id="productDescriptionLabel" text="Description du produit..." wrapText="true" styleClass="body-text"/>

                                <HBox spacing="18" alignment="CENTER_LEFT">
                                    <VBox spacing="6">
                                        <Label text="Quantite" styleClass="field-label"/>
                                        <Spinner fx:id="quantitySpinner" prefWidth="128" styleClass="premium-spinner"/>
                                    </VBox>
                                    <Label fx:id="availabilityCaptionLabel" text="Disponible" style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                                </HBox>

                                <Button fx:id="addToCartButton" onAction="#handleAddToCart" styleClass="btn-primary" prefWidth="280" prefHeight="54">
                                    <graphic>
                                        <HBox alignment="CENTER" spacing="10">
                                            <FontIcon iconLiteral="fas-cart-plus" iconSize="16" styleClass="ikonli-on-primary"/>
                                            <Label text="Ajouter au panier" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 14px;"/>
                                        </HBox>
                                    </graphic>
                                </Button>

                                <Region styleClass="divider"/>

                                <VBox spacing="10" styleClass="detail-feature-list">

                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-truck" iconSize="14" styleClass="ikonli-accent"/>
                                        <Label text="Livraison gratuite" styleClass="body-text"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-lock" iconSize="14" styleClass="ikonli-accent"/>
                                        <Label text="Paiement sécurisé" styleClass="body-text"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-undo-alt" iconSize="14" styleClass="ikonli-accent"/>
                                        <Label text="Retours sous 7 jours" styleClass="body-text"/>
                                    </HBox>

                                </VBox>

                                <Label fx:id="messageLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

    <VBox fx:id="toastLayer" spacing="10" pickOnBounds="false"
          StackPane.alignment="BOTTOM_RIGHT"
          style="-fx-padding: 0 18px 18px 0;"/>

    <StackPane fx:id="drawerScrim" visible="false" managed="false"
               onMouseClicked="#closeNotifications"
               style="-fx-background-color: rgba(0,0,0,0.22);"/>
    <VBox fx:id="drawerPanel" visible="false" managed="false" spacing="10"
          StackPane.alignment="CENTER_RIGHT"
          style="-fx-pref-width: 360px; -fx-max-width: 360px; -fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 0 1; -fx-padding: 16px;">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Notifications" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Fermer" onAction="#closeNotifications" styleClass="btn-outline"/>
        </HBox>
        <Button text="Marquer tout comme lu" onAction="#markAllRead" styleClass="btn-outline"/>
        <ListView fx:id="notificationsList" prefHeight="480" styleClass="table-premium"/>
    </VBox>

</StackPane>
