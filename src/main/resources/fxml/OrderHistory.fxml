<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.chrionline.ui.controller.OrderHistoryController"
           styleClass="root-pane">

    <VBox spacing="0" StackPane.alignment="TOP_LEFT">
        <!-- NAVBAR -->
        <HBox alignment="CENTER" styleClass="navbar" prefHeight="72">
            <HBox alignment="CENTER_LEFT" spacing="18" maxWidth="1200" HBox.hgrow="ALWAYS" style="-fx-padding: 0 40px;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="C" styleClass="logo-icon"/>
                    <Label text="ChriOnline" styleClass="brand-title-small"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="22">
                    <Button fx:id="navHomeBtn" text="Accueil" onAction="#goHome" styleClass="nav-pill"/>
                    <Button fx:id="navCartBtn" text="Panier" onAction="#goCart" styleClass="nav-pill"/>
                    <Button fx:id="navProfileBtn" text="Profil" onAction="#goProfile" styleClass="nav-pill"/>
                    <Button fx:id="navOrdersBtn" text="Commandes" onAction="#noop" styleClass="nav-pill"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="nav-actions">
                    <Button fx:id="bellButton" onAction="#toggleNotifications" styleClass="nav-pill nav-pill-icon">
                        <graphic>
                            <StackPane>
                                <FontIcon iconLiteral="fas-bell" iconSize="16" styleClass="ikonli-muted"/>
                                <Label fx:id="unreadBadge" text="0"
                                       visible="false" managed="false"
                                       styleClass="badge-unread"
                                       StackPane.alignment="TOP_RIGHT" />
                            </StackPane>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
        </HBox>

        <VBox maxWidth="1200" spacing="16" style="-fx-padding: 24px 40px 40px 40px;" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <FontIcon iconLiteral="fas-history" iconSize="18" styleClass="ikonli-accent"/>
                <Label text="Order History" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="statusFilter" prefWidth="220" styleClass="combo-box-premium"/>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="cardsContainer" spacing="14" style="-fx-padding: 6px 2px 20px 2px;"/>
                </content>
            </ScrollPane>
        </VBox>
    </VBox>

    <!-- Toast layer -->
    <VBox fx:id="toastLayer" spacing="10" pickOnBounds="false"
          StackPane.alignment="BOTTOM_RIGHT"
          style="-fx-padding: 0 18px 18px 0;"/>

    <StackPane fx:id="drawerScrim" visible="false" managed="false"
               onMouseClicked="#closeNotifications"
               style="-fx-background-color: rgba(0,0,0,0.22);"/>
    <VBox fx:id="drawerPanel" visible="false" managed="false" spacing="10"
          StackPane.alignment="CENTER_RIGHT"
          style="-fx-pref-width: 360px; -fx-max-width: 360px; -fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 0 1; -fx-padding: 16px;">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Notifications" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Fermer" onAction="#closeNotifications" styleClass="btn-outline"/>
        </HBox>
        <Button text="Marquer tout comme lu" onAction="#markAllRead" styleClass="btn-outline"/>
        <ListView fx:id="notificationsList" prefHeight="480" styleClass="table-premium"/>
    </VBox>

    <!-- Details modal -->
    <StackPane fx:id="detailsOverlay" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.68);">
        <VBox fx:id="detailsCard" spacing="14" maxWidth="760"
              style="-fx-background-color: rgba(255,255,255,0.98); -fx-background-radius: 20px; -fx-border-color: rgba(15,23,42,0.10); -fx-border-radius: 20px; -fx-padding: 22px 22px;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="detailsTitle" text="Order" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Fermer" onAction="#closeDetails" styleClass="btn-outline"/>
            </HBox>
            <Label fx:id="detailsMeta" text="" styleClass="body-text" wrapText="true"/>
            <Separator/>
            <Label text="Items" styleClass="field-label"/>
            <ListView fx:id="detailsItems" styleClass="table-premium" prefHeight="220"/>
            <Separator/>
            <Label text="Timeline" styleClass="field-label"/>
            <VBox fx:id="timelineBox" spacing="10"/>
        </VBox>
    </StackPane>

</StackPane>

