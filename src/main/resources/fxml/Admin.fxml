<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chrionline.ui.controller.AdminController"
      styleClass="root-pane"
      spacing="0">

    <HBox alignment="CENTER" styleClass="navbar" prefHeight="84">
        <HBox alignment="CENTER_LEFT" spacing="18" maxWidth="1380" HBox.hgrow="ALWAYS" style="-fx-padding: 0 28px;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ImageView fitWidth="46" fitHeight="46" preserveRatio="true" styleClass="app-logo-image">
                    <image>
                        <Image url="@/images/ChriOnline_logo.png"/>
                    </image>
                </ImageView>
                <Label text="ChriOnline" styleClass="brand-title-small"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="18">
                <Button fx:id="navHomeBtn" onAction="#handleOpenHome" styleClass="nav-pill">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <FontIcon iconLiteral="fas-home" iconSize="14" styleClass="ikonli-muted"/>
                            <Label text="Accueil" styleClass="nav-pill-text"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="navCatalogueBtn" onAction="#handleOpenCatalogue" styleClass="nav-pill">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <FontIcon iconLiteral="fas-th-large" iconSize="14" styleClass="ikonli-muted"/>
                            <Label text="Catalogue" styleClass="nav-pill-text"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <Region minWidth="16"/>

            <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                <TextField fx:id="headerSearchField"
                           promptText="Cherchez un produit, une marque ou une categorie"
                           onAction="#handleHeaderSearch"
                           styleClass="search-bar header-search-field"
                           HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleHeaderSearch" styleClass="header-search-button">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="ikonli-on-primary"/>
                            <Label text="Rechercher" styleClass="header-search-button-text"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="nav-actions">
                <MenuButton fx:id="accountMenuButton" text="Bonjour, Utilisateur" styleClass="nav-pill account-menu">
                    <graphic>
                        <FontIcon iconLiteral="fas-user-circle" iconSize="16" styleClass="ikonli-muted"/>
                    </graphic>
                    <items>
                        <MenuItem fx:id="accountProfileItem" text="Votre compte"/>
                        <MenuItem fx:id="accountOrdersItem" text="Vos commandes"/>
                        <MenuItem fx:id="accountAdminItem" text="Admin"/>
                        <MenuItem fx:id="accountLogoutItem" text="Deconnexion"/>
                    </items>
                </MenuButton>
                <Button onAction="#handleOpenCart" styleClass="nav-pill">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <FontIcon iconLiteral="fas-shopping-cart" iconSize="14" styleClass="ikonli-muted"/>
                            <Label text="Panier" style="-fx-text-fill: #334155; -fx-font-weight: 700;"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>
        </HBox>
    </HBox>

    <VBox spacing="18">
        <padding>
            <Insets top="24" right="28" bottom="24" left="28"/>
        </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Administration" styleClass="brand-title page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="&#8592; Retour catalogue" onAction="#handleBackToHome" styleClass="btn-outline"/>
        <Button onAction="#handleLogout" styleClass="btn-outline">
            <graphic>
                <HBox alignment="CENTER" spacing="6">
                    <FontIcon iconLiteral="fas-sign-out-alt" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Logout" style="-fx-text-fill: #64748b; -fx-font-weight: 600;"/>
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <VBox styleClass="auth-card" spacing="14" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>

        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="tab-premium" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Produits">
                    <StackPane>
                        <VBox spacing="10" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Produits" styleClass="field-label" style="-fx-font-size: 15px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Ajouter produit" onAction="#handleAddProductButton" styleClass="btn-primary" prefWidth="180"/>
                            </HBox>
                            <TableView fx:id="productsTable" styleClass="table-premium" minHeight="350" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colProdId" text="ID" prefWidth="70"/>
                                    <TableColumn fx:id="colProdName" text="Nom" prefWidth="220"/>
                                    <TableColumn fx:id="colProdCategory" text="Cat." prefWidth="90"/>
                                    <TableColumn fx:id="colProdPrice" text="Prix" prefWidth="110"/>
                                    <TableColumn fx:id="colProdStock" text="Stock" prefWidth="90"/>
                                    <TableColumn fx:id="colProdAction" text="Actions" prefWidth="220" style="-fx-alignment: CENTER;"/>
                                </columns>
                            </TableView>

                            <ScrollPane fitToWidth="true" VBox.vgrow="NEVER" prefViewportHeight="260" visible="false" managed="false">
                                <VBox fx:id="productFormContainer" spacing="14" fillWidth="true" maxWidth="Infinity">
                                    <Separator/>
                                    <HBox spacing="18" alignment="TOP_LEFT" fillHeight="true">
                                        <VBox spacing="12" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                            <TextField fx:id="prodNameField" promptText="Nom" styleClass="auth-field" maxWidth="Infinity"/>
                                            <ComboBox fx:id="prodCategoryCombo" promptText="Categorie" styleClass="combo-box-premium" maxWidth="Infinity"/>
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <TextField fx:id="prodPriceField" promptText="Prix" styleClass="auth-field" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                                <TextField fx:id="prodStockField" promptText="Stock" styleClass="auth-field" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                            </HBox>
                                            <TextArea fx:id="prodDescField" promptText="Description" prefRowCount="8" wrapText="true" VBox.vgrow="ALWAYS"/>
                                        </VBox>
                                        <VBox spacing="8" alignment="TOP_LEFT" prefWidth="340" minWidth="340">
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Button text="Ajouter des images" onAction="#handleChooseProductImages" styleClass="btn-secondary"/>
                                                <Label fx:id="prodImageFileNameLabel" text="Aucune selection" style="-fx-font-size: 12px; -fx-text-fill: #64748b;" maxWidth="150"/>
                                            </HBox>
                                            <HBox spacing="8" alignment="CENTER_LEFT">
                                                <Button text="Definir principale" onAction="#handleSetPrimaryProductImage" styleClass="btn-outline"/>
                                                <Button text="Supprimer" onAction="#handleRemoveSelectedProductImage" styleClass="btn-secondary"/>
                                            </HBox>
                                            <ListView fx:id="prodImagesList" minHeight="150" prefHeight="150" prefWidth="340" styleClass="table-premium"/>
                                            <StackPane prefWidth="340" prefHeight="180" style="-fx-background-color: #f8fafc; -fx-background-radius: 12px; -fx-border-color: #e2e8f0; -fx-border-radius: 12px; -fx-border-width: 1.5px;">
                                                <ImageView fx:id="prodImagePreview" fitWidth="320" fitHeight="160" preserveRatio="true"/>
                                                <Label fx:id="prodImagePreviewPlaceholderLabel" text="Aucune image" styleClass="image-placeholder"/>
                                            </StackPane>
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </ScrollPane>
                        </VBox>

                        <StackPane fx:id="productModalOverlay" visible="false" managed="false" pickOnBounds="true"
                                   style="-fx-background-color: rgba(15, 23, 42, 0.35);" alignment="CENTER">
                            <VBox spacing="12" alignment="TOP_CENTER" styleClass="auth-card"
                                  style="-fx-padding: 18px; -fx-max-width: 780px; -fx-max-height: 760px;">
                                <Label text="Ajouter / Modifier" styleClass="brand-title"/>
                                <ScrollPane fitToWidth="true" prefViewportWidth="700" prefViewportHeight="520"
                                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                            style="-fx-background-color: transparent; -fx-background-insets: 0;">
                                    <VBox fx:id="productModalFormHost" spacing="10" alignment="TOP_LEFT" fillWidth="true"/>
                                </ScrollPane>
                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="Enregistrer" onAction="#handleSaveProduct" styleClass="btn-primary" prefWidth="160"/>
                                    <Button text="Annuler" onAction="#handleCancelProductModal" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>
                        </StackPane>
                    </StackPane>
                </Tab>

                <Tab text="Commandes">
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Commandes" styleClass="field-label" style="-fx-font-size: 15px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="ordersSearchField" promptText="Rechercher (Order ID)" styleClass="search-bar" prefWidth="280"/>
                            <ComboBox fx:id="ordersStatusFilter" prefWidth="220" styleClass="combo-box-premium"/>
                        </HBox>
                        <TableView fx:id="ordersTable" styleClass="table-premium" prefHeight="360">
                            <columns>
                                <TableColumn fx:id="colOrderId" text="Order ID" prefWidth="230"/>
                                <TableColumn fx:id="colOrderUser" text="User" prefWidth="90"/>
                                <TableColumn fx:id="colOrderTotal" text="Total" prefWidth="110"/>
                                <TableColumn fx:id="colOrderStatus" text="Statut" prefWidth="140"/>
                                <TableColumn fx:id="colOrderAction" text="Actions" prefWidth="170" style="-fx-alignment: CENTER;"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab text="Utilisateurs">
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Liste des utilisateurs" styleClass="field-label" style="-fx-font-size: 15px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="usersSearchField" promptText="Rechercher (username/email)" styleClass="search-bar" prefWidth="320"/>
                            <ComboBox fx:id="usersRoleFilter" prefWidth="170" styleClass="combo-box-premium"/>
                            <ComboBox fx:id="usersSuspendedFilter" prefWidth="160" styleClass="combo-box-premium"/>
                        </HBox>
                        <TableView fx:id="usersTable" styleClass="table-premium" prefHeight="360">
                            <columns>
                                <TableColumn fx:id="colUserId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colUsername" text="Username" prefWidth="170"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                                <TableColumn fx:id="colRole" text="Role" prefWidth="90"/>
                                <TableColumn fx:id="colSuspended" text="Suspendu" prefWidth="100"/>
                                <TableColumn fx:id="colUserAction" text="Actions" prefWidth="160" style="-fx-alignment: CENTER;"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab text="Categories">
                    <StackPane>
                        <BorderPane>
                            <center>
                                <TableView fx:id="categoriesTable" styleClass="table-premium" prefHeight="300">
                                    <columns>
                                        <TableColumn fx:id="colCatId" text="ID" prefWidth="70"/>
                                        <TableColumn fx:id="colCatName" text="Nom" prefWidth="220"/>
                                        <TableColumn fx:id="colCatDesc" text="Description" prefWidth="380"/>
                                        <TableColumn fx:id="colCatAction" text="Actions" prefWidth="160" style="-fx-alignment: CENTER;"/>
                                    </columns>
                                </TableView>
                            </center>
                            <top>
                                <HBox alignment="CENTER_LEFT" spacing="10" BorderPane.alignment="CENTER_LEFT">
                                    <padding><Insets bottom="10"/></padding>
                                    <Label text="Gestion des categories" styleClass="field-label" style="-fx-font-size: 15px;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Ajouter categorie" onAction="#handleAddCategoryButton" styleClass="btn-primary" prefWidth="190"/>
                                </HBox>
                            </top>
                            <bottom>
                                <VBox fx:id="categoryFormContainer" spacing="10" visible="false" managed="false">
                                    <padding><Insets top="10"/></padding>
                                    <Separator/>
                                    <HBox spacing="10">
                                        <TextField fx:id="catNameField" promptText="Nom de la categorie" styleClass="auth-field" prefWidth="240"/>
                                        <TextField fx:id="catDescField" promptText="Description (optionnel)" styleClass="auth-field" HBox.hgrow="ALWAYS"/>
                                    </HBox>
                                    <HBox spacing="10" alignment="CENTER_RIGHT">
                                        <Button text="Enregistrer" onAction="#handleSaveCategory" styleClass="btn-primary" prefWidth="160"/>
                                    </HBox>
                                </VBox>
                            </bottom>
                        </BorderPane>

                        <StackPane fx:id="categoryModalOverlay" visible="false" managed="false" pickOnBounds="true"
                                   style="-fx-background-color: rgba(15, 23, 42, 0.35);" alignment="CENTER">
                            <VBox spacing="12" alignment="CENTER" styleClass="auth-card"
                                  style="-fx-padding: 18px; -fx-max-width: 480px; -fx-max-height: 420px;">
                                <Label text="Ajouter / Modifier" styleClass="brand-title"/>
                                <VBox fx:id="categoryModalFormHost" spacing="10" alignment="CENTER"/>
                                <HBox spacing="10" alignment="CENTER_RIGHT" VBox.vgrow="NEVER">
                                    <Button text="Annuler" onAction="#handleCancelCategoryModal" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>
                        </StackPane>
                    </StackPane>
                </Tab>
            </tabs>
        </TabPane>

        <Label fx:id="messageLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity"/>
    </VBox>
    </VBox>
</VBox>
