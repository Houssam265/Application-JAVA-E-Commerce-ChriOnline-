<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chrionline.ui.controller.AdminController"
      styleClass="root-pane"
      spacing="18">

    <padding>
        <Insets top="24" right="28" bottom="24" left="28"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Administration" styleClass="brand-title page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Retour catalogue" onAction="#handleBackToHome" styleClass="btn-outline"/>
    </HBox>

    <VBox styleClass="auth-card" spacing="14" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>

        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="tab-premium" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Produits">
                    <StackPane>
                        <VBox spacing="10" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Produits" styleClass="field-label" style="-fx-font-size: 15px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Ajouter produit" onAction="#handleAddProductButton" styleClass="btn-primary" prefWidth="180"/>
                        </HBox>
                        <TableView fx:id="productsTable" styleClass="table-premium" minHeight="350" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colProdId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colProdName" text="Nom" prefWidth="220"/>
                                <TableColumn fx:id="colProdCategory" text="Cat." prefWidth="90"/>
                                <TableColumn fx:id="colProdPrice" text="Prix" prefWidth="110"/>
                                <TableColumn fx:id="colProdStock" text="Stock" prefWidth="90"/>
                                <TableColumn fx:id="colProdAction" text="Actions" prefWidth="220" style="-fx-alignment: CENTER;"/>
                            </columns>
                        </TableView>

                        <!-- Scroll le formulaire pour ne pas “écraser” la table -->
                        <ScrollPane fitToWidth="true" VBox.vgrow="NEVER" prefViewportHeight="260" visible="false" managed="false">
                            <VBox fx:id="productFormContainer" spacing="10">
                                <Separator/>
                                <HBox spacing="10">
                                    <TextField fx:id="prodNameField" promptText="Nom" styleClass="auth-field" HBox.hgrow="ALWAYS"/>
                                    <ComboBox fx:id="prodCategoryCombo" promptText="Catégorie" styleClass="combo-box-premium" prefWidth="220"/>
                                </HBox>
                                <HBox spacing="10">
                                    <TextField fx:id="prodPriceField" promptText="Prix" styleClass="auth-field" prefWidth="160"/>
                                    <TextField fx:id="prodStockField" promptText="Stock" styleClass="auth-field" prefWidth="160"/>
                                    <VBox spacing="8" alignment="CENTER_LEFT" prefWidth="260">
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <Button text="Choisir l'image" onAction="#handleChooseProductImage" styleClass="btn-secondary"/>
                                            <Label fx:id="prodImageFileNameLabel" text="Aucune sélection" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                                        </HBox>
                                        <StackPane prefWidth="260" prefHeight="92" style="-fx-background-color: #f8fafc; -fx-background-radius: 12px; -fx-border-color: #e2e8f0; -fx-border-radius: 12px; -fx-border-width: 1.5px;">
                                            <ImageView fx:id="prodImagePreview" fitWidth="260" fitHeight="92" preserveRatio="true"/>
                                            <Label fx:id="prodImagePreviewPlaceholderLabel" text="Aucune image" styleClass="image-placeholder"/>
                                        </StackPane>
                                    </VBox>
                                </HBox>
                                <TextArea fx:id="prodDescField" promptText="Description" prefRowCount="2" wrapText="true"/>
                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="Enregistrer" onAction="#handleSaveProduct" styleClass="btn-primary" prefWidth="160"/>
                                </HBox>
                            </VBox>
                        </ScrollPane>
                        </VBox>

                        <!-- Centered modal for adding/editing products -->
                        <StackPane fx:id="productModalOverlay" visible="false" managed="false" pickOnBounds="true"
                                   style="-fx-background-color: rgba(15, 23, 42, 0.35);" alignment="CENTER">
                            <VBox spacing="12" alignment="CENTER" styleClass="auth-card"
                                  style="-fx-padding: 18px; -fx-max-width: 520px; -fx-max-height: 520px;">
                                <Label text="Ajouter / Modifier" styleClass="brand-title"/>
                                <VBox fx:id="productModalFormHost" spacing="10" alignment="CENTER"/>
                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="Annuler" onAction="#handleCancelProductModal" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>
                        </StackPane>
                    </StackPane>
                </Tab>

                <Tab text="Commandes">
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Commandes" styleClass="field-label" style="-fx-font-size: 15px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="ordersSearchField" promptText="Rechercher (Order ID)" styleClass="search-bar" prefWidth="280"/>
                            <ComboBox fx:id="ordersStatusFilter" prefWidth="220" styleClass="combo-box-premium"/>
                        </HBox>
                        <TableView fx:id="ordersTable" styleClass="table-premium" prefHeight="360">
                            <columns>
                                <TableColumn fx:id="colOrderId" text="Order ID" prefWidth="230"/>
                                <TableColumn fx:id="colOrderUser" text="User" prefWidth="90"/>
                                <TableColumn fx:id="colOrderTotal" text="Total" prefWidth="110"/>
                                <TableColumn fx:id="colOrderStatus" text="Statut" prefWidth="140"/>
                                <TableColumn fx:id="colOrderAction" text="Actions" prefWidth="170" style="-fx-alignment: CENTER;"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab text="Utilisateurs">
                    <VBox spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Liste des utilisateurs" styleClass="field-label" style="-fx-font-size: 15px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="usersSearchField" promptText="Rechercher (username/email)" styleClass="search-bar" prefWidth="320"/>
                            <ComboBox fx:id="usersRoleFilter" prefWidth="170" styleClass="combo-box-premium"/>
                            <ComboBox fx:id="usersSuspendedFilter" prefWidth="160" styleClass="combo-box-premium"/>
                        </HBox>
                        <TableView fx:id="usersTable" styleClass="table-premium" prefHeight="360">
                            <columns>
                                <TableColumn fx:id="colUserId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="colUsername" text="Username" prefWidth="170"/>
                                <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                                <TableColumn fx:id="colRole" text="Rôle" prefWidth="90"/>
                                <TableColumn fx:id="colSuspended" text="Suspendu" prefWidth="100"/>
                                <TableColumn fx:id="colUserAction" text="Actions" prefWidth="160" style="-fx-alignment: CENTER;"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab text="Catégories">
                    <StackPane>
                        <BorderPane>
                        <center>
                            <TableView fx:id="categoriesTable" styleClass="table-premium" prefHeight="300">
                                <columns>
                                    <TableColumn fx:id="colCatId"   text="ID"          prefWidth="70"/>
                                    <TableColumn fx:id="colCatName" text="Nom"         prefWidth="220"/>
                                    <TableColumn fx:id="colCatDesc" text="Description" prefWidth="380"/>
                                    <TableColumn fx:id="colCatAction" text="Actions" prefWidth="160" style="-fx-alignment: CENTER;"/>
                                </columns>
                            </TableView>
                        </center>
                        <top>
                            <HBox alignment="CENTER_LEFT" spacing="10" BorderPane.alignment="CENTER_LEFT">
                                <padding><Insets bottom="10"/></padding>
                                <Label text="Gestion des catégories" styleClass="field-label" style="-fx-font-size: 15px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Ajouter catégorie" onAction="#handleAddCategoryButton" styleClass="btn-primary" prefWidth="190"/>
                            </HBox>
                        </top>
                            <bottom>
                                <VBox fx:id="categoryFormContainer" spacing="10" visible="false" managed="false">
                                <padding><Insets top="10"/></padding>
                                <Separator/>
                                <HBox spacing="10">
                                    <TextField fx:id="catNameField"  promptText="Nom de la catégorie"     styleClass="auth-field" prefWidth="240"/>
                                    <TextField fx:id="catDescField"  promptText="Description (optionnel)" styleClass="auth-field" HBox.hgrow="ALWAYS"/>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_RIGHT">
                                    <Button text="Enregistrer"  onAction="#handleSaveCategory"   styleClass="btn-primary" prefWidth="160"/>
                                </HBox>
                            </VBox>
                        </bottom>
                    </BorderPane>

                    <!-- Centered modal for adding/editing categories -->
                    <StackPane fx:id="categoryModalOverlay" visible="false" managed="false" pickOnBounds="true"
                               style="-fx-background-color: rgba(15, 23, 42, 0.35);" alignment="CENTER">
                        <VBox spacing="12" alignment="CENTER" styleClass="auth-card"
                              style="-fx-padding: 18px; -fx-max-width: 480px; -fx-max-height: 420px;">
                            <Label text="Ajouter / Modifier" styleClass="brand-title" />
        
                            <VBox fx:id="categoryModalFormHost" spacing="10" alignment="CENTER"/>
                            <HBox spacing="10" alignment="CENTER_RIGHT" VBox.vgrow="NEVER">
                                <Button text="Annuler" onAction="#handleCancelCategoryModal" styleClass="btn-secondary"/>
                            </HBox>
                        </VBox>
                    </StackPane>
                </StackPane>
                </Tab>
            </tabs>
        </TabPane>

        <Label fx:id="messageLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity"/>
    </VBox>
</VBox>

