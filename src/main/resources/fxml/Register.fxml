<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Hyperlink?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.chrionline.ui.controller.RegisterController"
           styleClass="root-pane">

    <!-- Card centrée avec glassmorphism -->
    <VBox styleClass="auth-card" maxWidth="520" alignment="CENTER">
        <padding><Insets top="48" right="56" bottom="48" left="56"/></padding>
        <spacing>0</spacing>

        <!-- En-tête avec icône -->
        <VBox alignment="CENTER" spacing="12">
            <StackPane style="-fx-background-color: rgba(244,106,61,0.15); -fx-background-radius: 50%; -fx-padding: 18px;" VBox.vgrow="NEVER">
                <FontIcon iconLiteral="fas-user-plus" iconSize="28" styleClass="ikonli-accent"/>
            </StackPane>
            <Label text="ChriOnline" styleClass="brand-title"/>
            <Label text="Créez votre compte gratuitement" styleClass="brand-subtitle"/>
        </VBox>

        <Region prefHeight="28"/>

        <!-- Nom d'utilisateur -->
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <FontIcon iconLiteral="fas-user" iconSize="13" styleClass="ikonli-muted"/>
                <Label text="Nom d'utilisateur" styleClass="field-label"/>
            </HBox>
            <TextField fx:id="usernameField" promptText="Votre nom d'utilisateur" styleClass="auth-field"/>
            <Label fx:id="usernameError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="14"/>

        <!-- Email -->
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <FontIcon iconLiteral="fas-envelope" iconSize="13" styleClass="ikonli-muted"/>
                <Label text="Adresse email" styleClass="field-label"/>
            </HBox>
            <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="auth-field"/>
            <Label fx:id="emailError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="14"/>

        <!-- Mot de passe -->
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <FontIcon iconLiteral="fas-lock" iconSize="13" styleClass="ikonli-muted"/>
                <Label text="Mot de passe" styleClass="field-label"/>
            </HBox>
            <PasswordField fx:id="passwordField" promptText="Minimum 8 caractères" styleClass="auth-field"/>
            <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="14"/>

        <!-- Confirmation -->
        <VBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <FontIcon iconLiteral="fas-check-circle" iconSize="13" iconColor="#94a3b8"/>
                <Label text="Confirmer le mot de passe" styleClass="field-label"/>
            </HBox>
            <PasswordField fx:id="confirmPasswordField" promptText="Retapez votre mot de passe" styleClass="auth-field"/>
            <Label fx:id="confirmPasswordError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="14"/>

        <!-- Messages -->
        <Label fx:id="globalError" styleClass="global-error" wrapText="true" visible="false" managed="false"/>
        <Label fx:id="successMessage" styleClass="success-label" wrapText="true" visible="false" managed="false"/>

        <Region prefHeight="20"/>

        <!-- Bouton S'inscrire -->
        <Button fx:id="registerButton" onAction="#handleRegister" styleClass="btn-primary" maxWidth="Infinity" prefHeight="52">
            <graphic>
                <HBox alignment="CENTER" spacing="8">
                    <FontIcon iconLiteral="fas-rocket" iconSize="15" styleClass="ikonli-on-primary"/>
                    <Label text="Créer mon compte" style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 15px;"/>
                </HBox>
            </graphic>
        </Button>

        <Region prefHeight="16"/>

        <!-- Lien vers connexion -->
        <HBox alignment="CENTER" spacing="8">
            <Label text="Déjà un compte ?" styleClass="link-text"/>
            <Hyperlink text="Se connecter" styleClass="link-action" onAction="#goToLogin"/>
        </HBox>

        <!-- Loading -->
        <HBox alignment="CENTER">
            <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" styleClass="loading-spinner" prefWidth="36" prefHeight="36"/>
        </HBox>

    </VBox>
</StackPane>
