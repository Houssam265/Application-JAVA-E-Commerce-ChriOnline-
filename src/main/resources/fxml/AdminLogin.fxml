<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chrionline.ui.controller.AdminLoginController"
      styleClass="split-pane-root">

    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="left-pane" maxWidth="700" minWidth="580">
        <VBox styleClass="auth-shell" alignment="CENTER_LEFT" maxWidth="472" prefWidth="472" minWidth="472">
            <VBox spacing="26" styleClass="auth-card auth-card-body" alignment="CENTER_LEFT" maxWidth="472" prefWidth="472" minWidth="472">

                <HBox alignment="CENTER_LEFT" spacing="14" maxWidth="440">
                    <ImageView fitWidth="52" fitHeight="52" preserveRatio="true" styleClass="app-logo-image">
                        <image>
                            <Image url="@/images/ChriOnline_logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="Admin Portal" styleClass="brand-title-small"/>
                </HBox>

                <VBox spacing="10" maxWidth="440" prefWidth="440" minWidth="440" styleClass="auth-header-block">
                    <Label text="Secure Authentication" styleClass="page-title"/>
                    <Label text="Challenge-Response RSA Login" styleClass="brand-subtitle"/>
                </VBox>

                <VBox spacing="18" maxWidth="440" prefWidth="440" minWidth="440" styleClass="auth-section">
                    <VBox spacing="8" maxWidth="440" prefWidth="440" minWidth="440">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <FontIcon iconLiteral="fas-user-shield" iconSize="14" styleClass="ikonli-muted"/>
                            <Label text="Admin Username" styleClass="field-label"/>
                        </HBox>
                        <TextField fx:id="adminUsernameField" promptText="Enter your Admin Username" styleClass="auth-field" maxWidth="440" prefWidth="440" minWidth="440"/>
                        <Label fx:id="adminUsernameError" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="440" prefWidth="440" minWidth="440">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <FontIcon iconLiteral="fas-key" iconSize="14" styleClass="ikonli-muted"/>
                            <Label text="Private Key (RSA)" styleClass="field-label"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Select Key File" onAction="#handleSelectKeyFile" styleClass="btn-outline"/>
                            <Label fx:id="keyFileLabel" text="No file selected" style="-fx-text-fill: #94a3b8;"/>
                        </HBox>
                        <Label fx:id="keyError" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>
                </VBox>

                <Label fx:id="globalError" styleClass="global-error" wrapText="true" visible="false" managed="false" maxWidth="440" prefWidth="440" minWidth="440" alignment="CENTER"/>

                <VBox spacing="16" maxWidth="440" prefWidth="440" minWidth="440" styleClass="login-actions">
                    <Button fx:id="loginButton" text="Authenticate  →" styleClass="btn-primary" maxWidth="440" prefWidth="440" minWidth="440" onAction="#handleLogin"/>

                    <HBox alignment="CENTER">
                        <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" styleClass="loading-spinner" prefWidth="38" prefHeight="38"/>
                    </HBox>
                </VBox>

                <HBox alignment="CENTER" spacing="6" maxWidth="440" prefWidth="440" minWidth="440">
                    <Hyperlink text="← Back to Customer Login" styleClass="link-action" onAction="#goToLogin"/>
                </HBox>

            </VBox>
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="right-pane" minWidth="420">
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 60px 50px;">
            <HBox alignment="CENTER" spacing="32">
                <VBox alignment="CENTER" spacing="8">
                    <StackPane style="-fx-background-color: rgba(34,197,94,0.2); -fx-background-radius: 50%; -fx-padding: 18px;">
                        <FontIcon iconLiteral="fas-shield-alt" iconSize="28" styleClass="ikonli-green"/>
                    </StackPane>
                </VBox>
            </HBox>

            <Label text="Admin Security" styleClass="hero-title" textAlignment="CENTER"/>
            <Label text="Your private key is never sent over the network.&#10;We verify your identity locally using RSA." styleClass="hero-subtitle" textAlignment="CENTER"/>
        </VBox>
    </VBox>
</HBox>
