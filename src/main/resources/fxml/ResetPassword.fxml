<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.chrionline.ui.controller.ResetPasswordController"
      styleClass="split-pane-root">

    <!-- LEFT SIDE: Form -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="left-pane" maxWidth="640" minWidth="480">
        <VBox spacing="22" maxWidth="500" prefWidth="500">

            <!-- Logo area -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <ImageView fitWidth="52" fitHeight="52" preserveRatio="true" styleClass="app-logo-image">
                    <image>
                        <Image url="@/images/ChriOnline_logo.png"/>
                    </image>
                </ImageView>
                <Label text="ChriOnline" styleClass="brand-title-small"/>
            </HBox>

            <Region prefHeight="20" />

            <!-- Heading -->
            <VBox spacing="8" maxWidth="420">
                <Label text="Reset your password" styleClass="page-title"/>
                <Label text="Enter the token from your email and choose a new password" styleClass="brand-subtitle"/>
            </VBox>

            <Region prefHeight="10" />

            <!-- TOKEN -->
            <VBox spacing="8" maxWidth="420">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-key" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Reset Code" styleClass="field-label"/>
                </HBox>
                <TextField fx:id="tokenField" promptText="Enter the 6-digit code from your email" styleClass="auth-field" maxWidth="Infinity"/>
                <Label fx:id="tokenError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- NEW PASSWORD -->
            <VBox spacing="8" maxWidth="420">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-lock" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="New Password" styleClass="field-label"/>
                </HBox>
                <StackPane alignment="CENTER_RIGHT" maxWidth="Infinity">
                    <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="auth-field"/>
                    <TextField fx:id="passwordTextField" promptText="••••••••" styleClass="auth-field" visible="false"/>
                    <Button fx:id="togglePasswordButton" styleClass="eye-button" onAction="#togglePasswordVisibility" focusTraversable="false">
                        <graphic>
                            <FontIcon fx:id="togglePasswordIcon" iconLiteral="fas-eye-slash" iconSize="14" styleClass="ikonli-muted"/>
                        </graphic>
                    </Button>
                </StackPane>
                <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- CONFIRM PASSWORD -->
            <VBox spacing="8" maxWidth="420">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fas-lock" iconSize="14" styleClass="ikonli-muted"/>
                    <Label text="Confirm New Password" styleClass="field-label"/>
                </HBox>
                <StackPane alignment="CENTER_RIGHT" maxWidth="Infinity">
                    <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="auth-field"/>
                    <TextField fx:id="confirmPasswordTextField" promptText="••••••••" styleClass="auth-field" visible="false"/>
                    <Button fx:id="toggleConfirmPasswordButton" styleClass="eye-button" onAction="#toggleConfirmPasswordVisibility" focusTraversable="false">
                        <graphic>
                            <FontIcon fx:id="toggleConfirmPasswordIcon" iconLiteral="fas-eye-slash" iconSize="14" styleClass="ikonli-muted"/>
                        </graphic>
                    </Button>
                </StackPane>
                <Label fx:id="confirmPasswordError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- ERROR -->
            <Label fx:id="globalError" styleClass="global-error" wrapText="true" visible="false" managed="false"/>

            <!-- ACTION BUTTONS -->
            <VBox spacing="14">
                <Button fx:id="resetButton" text="Reset Password  →" styleClass="btn-primary" maxWidth="Infinity" onAction="#handleResetPassword"/>

                <HBox alignment="CENTER">
                    <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" styleClass="loading-spinner" prefWidth="38" prefHeight="38"/>
                </HBox>
            </VBox>

            <!-- BACK TO LOGIN -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Remember your password?" styleClass="link-text"/>
                <Hyperlink text="Sign In" styleClass="link-action" onAction="#goToLogin"/>
            </HBox>

        </VBox>
    </VBox>

    <!-- RIGHT SIDE: Hero Panel -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="right-pane" minWidth="420">
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 60px 50px;">

            <!-- Feature icons row -->
            <HBox alignment="CENTER" spacing="32">
                <VBox alignment="CENTER" spacing="8">
                    <FontIcon iconLiteral="fas-shield-alt" iconSize="48" styleClass="feature-icon"/>
                    <Label text="Secure Reset" styleClass="feature-title"/>
                    <Label text="Your password is protected with industry-standard encryption" styleClass="feature-subtitle" textAlignment="CENTER"/>
                </VBox>
            </HBox>

        </VBox>
    </VBox>

</HBox>