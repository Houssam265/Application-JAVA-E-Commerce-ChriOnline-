<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.chrionline.ui.controller.LandingController"
           styleClass="root-pane">
    <ScrollPane fitToWidth="true" styleClass="content-scroll" StackPane.alignment="TOP_LEFT">
        <content>
            <VBox spacing="0" style="-fx-background-color: transparent;">

                <HBox alignment="CENTER" styleClass="navbar" prefHeight="84">
                    <HBox alignment="CENTER_LEFT" spacing="18" maxWidth="1380" HBox.hgrow="ALWAYS" style="-fx-padding: 0 28px;">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <ImageView fitWidth="46" fitHeight="46" preserveRatio="true" styleClass="app-logo-image">
                                <image>
                                    <Image url="@/images/ChriOnline_logo.png"/>
                                </image>
                            </ImageView>
                            <Label text="ChriOnline" styleClass="brand-title-small"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox alignment="CENTER" spacing="18">
                            <Button fx:id="navHomeBtn" onAction="#noop" styleClass="nav-pill">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-home" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Accueil" styleClass="nav-pill-text"/>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button fx:id="navCatalogueBtn" onAction="#handleOpenCatalogue" styleClass="nav-pill">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-th-large" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Catalogue" styleClass="nav-pill-text"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>

                        <Region minWidth="16"/>

                        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                            <TextField fx:id="headerSearchField"
                                       promptText="Cherchez un produit, une marque ou une categorie"
                                       onAction="#handleHeaderSearch"
                                       styleClass="search-bar header-search-field"
                                       HBox.hgrow="ALWAYS"/>
                            <Button onAction="#handleHeaderSearch" styleClass="header-search-button">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-search" iconSize="14" styleClass="ikonli-on-primary"/>
                                        <Label text="Rechercher" styleClass="header-search-button-text"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="nav-actions">
                            <MenuButton fx:id="accountMenuButton" text="Bonjour, Utilisateur" styleClass="nav-pill account-menu">
                                <graphic>
                                    <FontIcon iconLiteral="fas-user-circle" iconSize="16" styleClass="ikonli-muted"/>
                                </graphic>
                                <items>
                                    <MenuItem fx:id="accountProfileItem" text="Votre compte"/>
                                    <MenuItem fx:id="accountOrdersItem" text="Vos commandes"/>
                                    <MenuItem fx:id="accountAdminItem" text="Admin"/>
                                    <MenuItem fx:id="accountLogoutItem" text="Deconnexion"/>
                                </items>
                            </MenuButton>
                            <Button fx:id="bellButton" onAction="#toggleNotifications" styleClass="nav-pill nav-pill-icon">
                                <graphic>
                                    <StackPane>
                                        <FontIcon iconLiteral="fas-bell" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label fx:id="unreadBadge" text="0"
                                               visible="false" managed="false"
                                               styleClass="badge-unread"
                                               StackPane.alignment="TOP_RIGHT"/>
                                    </StackPane>
                                </graphic>
                            </Button>
                            <Button onAction="#handleOpenCart" styleClass="nav-pill">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-shopping-cart" iconSize="14" styleClass="ikonli-muted"/>
                                        <Label text="Panier" style="-fx-text-fill: #334155; -fx-font-weight: 700;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>
                    </HBox>
                </HBox>

                <StackPane styleClass="hero-section">
                    <VBox alignment="CENTER_LEFT" spacing="24" maxWidth="1200" style="-fx-padding: 90px 60px;">
                        <Label text="New Collection 2026" styleClass="hero-badge"/>
                        <Label text="Discover products&#10;you'll love" styleClass="hero-super-title"/>
                        <Label text="Browse our strongest selection, then jump into the full catalogue to filter by category and explore every product." styleClass="hero-subtitle" wrapText="true"/>
                        <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 10px 0 0 0;">
                            <Button onAction="#handleShopNow" styleClass="btn-primary">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="8">
                                        <FontIcon iconLiteral="fas-bolt" iconSize="14" styleClass="ikonli-on-primary"/>
                                        <Label text="Open Catalogue" style="-fx-text-fill: white; -fx-font-weight: 700;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </HBox>
                    </VBox>
                </StackPane>

                <HBox alignment="CENTER" spacing="0" style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent; -fx-border-width:1px; -fx-padding: 30px 20px;">
                    <HBox alignment="CENTER" spacing="70" maxWidth="1100" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER" spacing="14">
                            <StackPane style="-fx-background-color: rgba(244,106,61,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                                <FontIcon iconLiteral="fas-truck" iconSize="22" styleClass="ikonli-accent"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Free Shipping" styleClass="trust-title"/>
                                <Label text="On orders" styleClass="trust-subtitle"/>
                            </VBox>
                        </HBox>
                        <HBox alignment="CENTER" spacing="14">
                            <StackPane style="-fx-background-color: rgba(192,132,252,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                                <FontIcon iconLiteral="fas-shield-alt" iconSize="22" styleClass="ikonli-purple"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Secure Payments" styleClass="trust-title"/>
                                <Label text="100% protected" styleClass="trust-subtitle"/>
                            </VBox>
                        </HBox>
                        <HBox alignment="CENTER" spacing="14">
                            <StackPane style="-fx-background-color: rgba(34,197,94,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                                <FontIcon iconLiteral="fas-undo" iconSize="22" styleClass="ikonli-green"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Easy Returns" styleClass="trust-title"/>
                                <Label text="30-day guarantee" styleClass="trust-subtitle"/>
                            </VBox>
                        </HBox>
                        <HBox alignment="CENTER" spacing="14">
                            <StackPane style="-fx-background-color: rgba(251,191,36,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                                <FontIcon iconLiteral="fas-headset" iconSize="22" styleClass="ikonli-yellow"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="24/7 Support" styleClass="trust-title"/>
                                <Label text="Always here for you" styleClass="trust-subtitle"/>
                            </VBox>
                        </HBox>
                    </HBox>
                </HBox>

                <VBox alignment="TOP_CENTER" style="-fx-padding: 50px 40px 80px 40px;">
                    <VBox maxWidth="1200" spacing="46" VBox.vgrow="ALWAYS">
                        <VBox spacing="24">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <FontIcon iconLiteral="fas-fire" iconSize="18" styleClass="ikonli-accent"/>
                                <Label text="Top Features" styleClass="section-title"/>
                            </HBox>
                            <Label text="Les 4 produits les plus vendus du moment." styleClass="body-text"/>
                            <FlowPane fx:id="productsGrid" hgap="20" vgap="20" styleClass="products-grid"/>
                        </VBox>

                        <VBox spacing="24">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <FontIcon iconLiteral="fas-star" iconSize="18" styleClass="ikonli-accent"/>
                                <Label text="Nouveautes" styleClass="section-title"/>
                            </HBox>
                            <Label text="Les 4 produits ajoutes le plus recemment." styleClass="body-text"/>
                            <FlowPane fx:id="recentProductsGrid" hgap="20" vgap="20" styleClass="products-grid"/>
                        </VBox>
                    </VBox>
                </VBox>

                <HBox styleClass="footer-section" alignment="CENTER">
                    <VBox maxWidth="1200" HBox.hgrow="ALWAYS" spacing="28" style="-fx-padding: 56px 40px 32px 40px;">
                        <HBox spacing="60" alignment="TOP_LEFT">
                            <VBox spacing="16" prefWidth="420">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <ImageView fitWidth="46" fitHeight="46" preserveRatio="true" styleClass="app-logo-image">
                                        <image>
                                            <Image url="@/images/ChriOnline_logo.png"/>
                                        </image>
                                    </ImageView>
                                    <Label text="ChriOnline" styleClass="footer-brand"/>
                                </HBox>
                                <Label text="ChriOnline met en avant ses meilleures ventes sur l'accueil et propose un catalogue complet avec filtres pour explorer tout le stock." styleClass="footer-text" wrapText="true"/>
                            </VBox>
                            <VBox spacing="14" alignment="TOP_LEFT">
                                <Label text="NAVIGATION" styleClass="footer-header"/>
                                <Button text="Accueil" onAction="#noop" styleClass="footer-link"
                                        style="-fx-background-color: transparent; -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                                <Button text="Catalogue" onAction="#handleOpenCatalogue" styleClass="footer-link"
                                        style="-fx-background-color: transparent; -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                                <Button text="Panier" onAction="#handleOpenCart" styleClass="footer-link"
                                        style="-fx-background-color: transparent; -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                                <Button text="Profil" onAction="#handleOpenProfile" styleClass="footer-link"
                                        style="-fx-background-color: transparent; -fx-padding: 0; -fx-alignment: CENTER_LEFT;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="18">
                            <Region style="-fx-background-color: rgba(255,255,255,0.07); -fx-pref-height: 1px;"/>
                            <Label text="Copyright 2026 ChriOnline" styleClass="footer-text"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </ScrollPane>

    <VBox fx:id="toastLayer" spacing="10" pickOnBounds="false"
          StackPane.alignment="BOTTOM_RIGHT"
          style="-fx-padding: 0 18px 18px 0;"/>

    <StackPane fx:id="drawerScrim" visible="false" managed="false"
               onMouseClicked="#closeNotifications"
               style="-fx-background-color: rgba(0,0,0,0.22);"/>
    <VBox fx:id="drawerPanel" visible="false" managed="false" spacing="10"
          StackPane.alignment="CENTER_RIGHT"
          style="-fx-pref-width: 360px; -fx-max-width: 360px; -fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 0 1; -fx-padding: 16px;">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Notifications" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Fermer" onAction="#closeNotifications" styleClass="btn-outline"/>
        </HBox>
        <Button text="Marquer tout comme lu" onAction="#markAllRead" styleClass="btn-outline"/>
        <ListView fx:id="notificationsList" prefHeight="480" styleClass="table-premium"/>
    </VBox>
</StackPane>
