<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.chrionline.ui.controller.HomeController"
            styleClass="root-pane">

    <top>
        <VBox spacing="20" styleClass="app-container">
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="ChriOnline | Catalogue" styleClass="brand-title page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="adminButton" text="Admin" onAction="#handleOpenAdmin" styleClass="btn-outline" visible="false" managed="false"/>
                <Button fx:id="cartButton" text="Panier" onAction="#handleOpenCart" styleClass="btn-outline"/>
                <Label fx:id="connectedLabel" text="Connecté" styleClass="status-pill"/>
            </HBox>

            <!-- Barre de recherche et Filtre -->
            <HBox spacing="16" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Rechercher un produit par nom..."
                           styleClass="search-bar"
                           HBox.hgrow="ALWAYS"/>
                
                <ComboBox fx:id="categoryCombo"
                          styleClass="combo-box-premium"
                          promptText="Catégories"
                          prefWidth="220"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <!-- ScrollPane transparent pour la grille de produits -->
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <content>
                <FlowPane fx:id="productsGrid" hgap="24" vgap="24" styleClass="products-grid">
                    <!-- Les cartes produits seront injectées ici par le contrôleur -->
                </FlowPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
