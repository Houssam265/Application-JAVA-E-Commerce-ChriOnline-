<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.chrionline.ui.controller.HomeController"
            fitToWidth="true" styleClass="root-pane content-scroll">
    <content>
        <VBox spacing="0" style="-fx-background-color: transparent;">

            <!-- ══════════════════ NAVBAR ══════════════════ -->
            <HBox alignment="CENTER" styleClass="navbar" prefHeight="72">
                <HBox alignment="CENTER_LEFT" spacing="24" maxWidth="1200" HBox.hgrow="ALWAYS" style="-fx-padding: 0 40px;">

                    <!-- LOGO -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="C" styleClass="logo-icon"/>
                        <Label text="ChriOnline" styleClass="brand-title-small"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- NAV LINKS -->
                    <HBox alignment="CENTER" spacing="32">
                        <HBox alignment="CENTER" spacing="6">
                            <FontIcon iconLiteral="fas-home" iconSize="13" styleClass="ikonli-muted"/>
                            <Label text="Home" styleClass="nav-link"/>
                        </HBox>
                        <HBox alignment="CENTER" spacing="6">
                            <FontIcon iconLiteral="fas-th-large" iconSize="13" styleClass="ikonli-muted"/>
                            <Label text="Catalogue" styleClass="nav-link"/>
                        </HBox>
                        <HBox alignment="CENTER" spacing="6">
                            <FontIcon iconLiteral="fas-tag" iconSize="13" styleClass="ikonli-muted"/>
                            <Label text="Deals" styleClass="nav-link"/>
                        </HBox>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- ACTIONS -->
                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button fx:id="adminButton" onAction="#handleOpenAdmin" styleClass="btn-outline" visible="false" managed="false">
                            <graphic>
                                <HBox alignment="CENTER" spacing="6">
                                    <FontIcon iconLiteral="fas-user-shield" iconSize="14" styleClass="ikonli-muted"/>
                                    <Label text="Admin" style="-fx-text-fill: #64748b; -fx-font-weight: 600;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <Button fx:id="cartButton" onAction="#handleOpenCart" styleClass="btn-outline">
                            <graphic>
                                <HBox alignment="CENTER" spacing="6">
                                    <FontIcon iconLiteral="fas-shopping-cart" iconSize="14" styleClass="ikonli-muted"/>
                                    <Label text="Cart" style="-fx-text-fill: #64748b; -fx-font-weight: 600;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <Label fx:id="connectedLabel" text="● Online" styleClass="status-pill"/>
                    </HBox>
                </HBox>
            </HBox>

            <!-- ══════════════════ HERO ══════════════════ -->
            <StackPane styleClass="hero-section">
                <VBox alignment="CENTER_LEFT" spacing="24" maxWidth="1200" style="-fx-padding: 90px 60px;">
                    <Label text="✨  New Collection 2025" styleClass="hero-badge" />
                    <Label text="Discover products&#10;you'll love" styleClass="hero-super-title"/>
                    <Label text="Curated collections from premium brands. Quality you can&#10;trust, prices you'll appreciate." styleClass="hero-subtitle"/>
                    <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 10px 0 0 0;">
                        <Button styleClass="btn-primary">
                            <graphic>
                                <HBox alignment="CENTER" spacing="8">
                                    <FontIcon iconLiteral="fas-bolt" iconSize="14" styleClass="ikonli-on-primary"/>
                                    <Label text="Shop Now" style="-fx-text-fill: white; -fx-font-weight: 700;"/>
                                </HBox>
                            </graphic>
                        </Button>
                        <Button text="Browse Catalogue" styleClass="btn-hero-secondary" />
                    </HBox>
                </VBox>
            </StackPane>

            <!-- ══════════════════ TRUST BADGES ══════════════════ -->
            <HBox alignment="CENTER" spacing="0" style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent; -fx-border-width:1px; -fx-padding: 30px 20px;">
                <HBox alignment="CENTER" spacing="70" maxWidth="1100" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER" spacing="14">
                        <StackPane style="-fx-background-color: rgba(244,106,61,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                            <FontIcon iconLiteral="fas-truck" iconSize="22" styleClass="ikonli-accent"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Free Shipping" styleClass="trust-title"/>
                            <Label text="On orders over $50" styleClass="trust-subtitle"/>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER" spacing="14">
                        <StackPane style="-fx-background-color: rgba(192,132,252,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                            <FontIcon iconLiteral="fas-shield-alt" iconSize="22" styleClass="ikonli-purple"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Secure Payments" styleClass="trust-title"/>
                            <Label text="100% protected" styleClass="trust-subtitle"/>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER" spacing="14">
                        <StackPane style="-fx-background-color: rgba(34,197,94,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                            <FontIcon iconLiteral="fas-undo" iconSize="22" styleClass="ikonli-green"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="Easy Returns" styleClass="trust-title"/>
                            <Label text="30-day guarantee" styleClass="trust-subtitle"/>
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER" spacing="14">
                        <StackPane style="-fx-background-color: rgba(251,191,36,0.12); -fx-background-radius: 50%; -fx-padding: 14px;">
                            <FontIcon iconLiteral="fas-headset" iconSize="22" styleClass="ikonli-yellow"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label text="24/7 Support" styleClass="trust-title"/>
                            <Label text="Always here for you" styleClass="trust-subtitle"/>
                        </VBox>
                    </HBox>
                </HBox>
            </HBox>

            <!-- ══════════════════ CATALOGUE ══════════════════ -->
            <VBox alignment="TOP_CENTER" style="-fx-padding: 50px 40px 80px 40px;">
                <VBox maxWidth="1200" spacing="40" VBox.vgrow="ALWAYS">

                    <!-- Category Pills -->
                    <VBox spacing="18">
                        <HBox alignment="CENTER_LEFT">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <FontIcon iconLiteral="fas-layer-group" iconSize="18" styleClass="ikonli-accent"/>
                                <Label text="Shop by Category" styleClass="section-title"/>
                            </HBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="View All →" styleClass="link-action-small"/>
                        </HBox>
                        <FlowPane fx:id="categoryPills" hgap="12" vgap="12" alignment="CENTER_LEFT">
                            <!-- Catégories chargées depuis la BD (GET_CATEGORIES) -->
                        </FlowPane>
                    </VBox>

                    <!-- Recherche -->
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <StackPane HBox.hgrow="ALWAYS">
                            <TextField fx:id="searchField" promptText="🔍  Search products..." styleClass="search-bar"/>
                        </StackPane>
                    </HBox>

                    <!-- Products Grid -->
                    <VBox spacing="20">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <FontIcon iconLiteral="fas-fire" iconSize="18" styleClass="ikonli-accent"/>
                            <Label text="Featured Products" styleClass="section-title"/>
                        </HBox>
                        <FlowPane fx:id="productsGrid" hgap="20" vgap="20" styleClass="products-grid">
                            <!-- Products injected here dynamically -->
                        </FlowPane>
                    </VBox>

                    <!-- CTA Banner -->
                    <StackPane styleClass="cta-banner">
                        <VBox alignment="CENTER" spacing="18" style="-fx-padding: 60px 32px;">
                            <Label text="🎁  Get 20% off your first order" styleClass="cta-title"/>
                            <Label text="Subscribe to our newsletter and receive an exclusive discount code." styleClass="cta-subtitle"/>
                            <HBox alignment="CENTER" spacing="14">
                                <TextField promptText="Enter your email..." styleClass="cta-input" prefWidth="360"/>
                                <Button styleClass="btn-dark">
                                    <graphic>
                                        <HBox alignment="CENTER" spacing="8">
                                            <FontIcon iconLiteral="fas-paper-plane" iconSize="13" styleClass="ikonli-on-primary"/>
                                            <Label text="Subscribe" style="-fx-text-fill: white; -fx-font-weight: 700;"/>
                                        </HBox>
                                    </graphic>
                                </Button>
                            </HBox>
                        </VBox>
                    </StackPane>
                </VBox>
            </VBox>

            <!-- ══════════════════ FOOTER ══════════════════ -->
            <HBox styleClass="footer-section" alignment="CENTER">
                <VBox maxWidth="1200" HBox.hgrow="ALWAYS" spacing="50" style="-fx-padding: 70px 40px 40px 40px;">
                    <HBox spacing="80">
                        <VBox spacing="16" prefWidth="280">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="C" styleClass="logo-icon"/>
                                <Label text="ChriOnline" styleClass="footer-brand"/>
                            </HBox>
                            <Label text="Your premium destination for quality&#10;products. Shop with confidence." styleClass="footer-text" wrapText="true"/>
                            <HBox spacing="14">
                                <FontIcon iconLiteral="fab-facebook" iconSize="18" styleClass="ikonli-dim"/>
                                <FontIcon iconLiteral="fab-twitter" iconSize="18" styleClass="ikonli-dim"/>
                                <FontIcon iconLiteral="fab-instagram" iconSize="18" styleClass="ikonli-dim"/>
                                <FontIcon iconLiteral="fab-linkedin" iconSize="18" styleClass="ikonli-dim"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="14">
                            <Label text="SHOP" styleClass="footer-header"/>
                            <Label text="All Products" styleClass="footer-link"/>
                            <Label text="Electronics" styleClass="footer-link"/>
                            <Label text="Fashion" styleClass="footer-link"/>
                            <Label text="Home &amp; Living" styleClass="footer-link"/>
                        </VBox>
                        <VBox spacing="14">
                            <Label text="ACCOUNT" styleClass="footer-header"/>
                            <Label text="My Profile" styleClass="footer-link"/>
                            <Label text="Orders" styleClass="footer-link"/>
                            <Label text="Wishlist" styleClass="footer-link"/>
                            <Label text="Settings" styleClass="footer-link"/>
                        </VBox>
                        <VBox spacing="14">
                            <Label text="COMPANY" styleClass="footer-header"/>
                            <Label text="About Us" styleClass="footer-link"/>
                            <Label text="Contact" styleClass="footer-link"/>
                            <Label text="FAQ" styleClass="footer-link"/>
                            <Label text="Privacy Policy" styleClass="footer-link"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="24">
                        <Region style="-fx-background-color: rgba(255,255,255,0.07); -fx-pref-height: 1px;"/>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="© 2025 ChriOnline. All rights reserved." styleClass="footer-text"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox spacing="28">
                                <Label text="Privacy" styleClass="footer-link"/>
                                <Label text="Terms" styleClass="footer-link"/>
                                <Label text="Support" styleClass="footer-link"/>
                            </HBox>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
