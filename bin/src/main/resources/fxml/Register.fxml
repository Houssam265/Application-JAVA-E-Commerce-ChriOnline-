<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.chrionline.ui.controller.RegisterController"
           styleClass="root-pane">

    <!-- Carte d'inscription centrée -->
    <VBox styleClass="auth-card" maxWidth="460" maxHeight="680" alignment="CENTER">
        <padding><Insets top="40" right="48" bottom="40" left="48"/></padding>
        <spacing>0</spacing>

        <!-- En-tête -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="ChriOnline" styleClass="brand-title"/>
            <Label text="Créez votre compte gratuitement" styleClass="brand-subtitle"/>
        </VBox>

        <Region prefHeight="28"/>

        <!-- Champ Nom d'utilisateur -->
        <VBox spacing="6">
            <Label text="Nom d'utilisateur" styleClass="field-label"/>
            <TextField fx:id="usernameField"
                       promptText="Votre nom d'utilisateur"
                       styleClass="auth-field"/>
            <Label fx:id="usernameError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="16"/>

        <!-- Champ Email -->
        <VBox spacing="6">
            <Label text="Adresse email" styleClass="field-label"/>
            <TextField fx:id="emailField"
                       promptText="exemple@email.com"
                       styleClass="auth-field"/>
            <Label fx:id="emailError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="16"/>

        <!-- Champ Mot de passe -->
        <VBox spacing="6">
            <Label text="Mot de passe" styleClass="field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Minimum 8 caractères"
                           styleClass="auth-field"/>
            <Label fx:id="passwordError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="16"/>

        <!-- Champ Confirmation mot de passe -->
        <VBox spacing="6">
            <Label text="Confirmer le mot de passe" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Retapez votre mot de passe"
                           styleClass="auth-field"/>
            <Label fx:id="confirmPasswordError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <Region prefHeight="8"/>

        <!-- Message d'erreur global (serveur) -->
        <Label fx:id="globalError"
               styleClass="global-error"
               wrapText="true"
               visible="false"
               managed="false"/>

        <!-- Message de succès -->
        <Label fx:id="successMessage"
               styleClass="success-label"
               wrapText="true"
               visible="false"
               managed="false"/>

        <Region prefHeight="20"/>

        <!-- Bouton S'inscrire -->
        <Button fx:id="registerButton"
                text="Créer mon compte"
                styleClass="btn-primary"
                maxWidth="Infinity"
                onAction="#handleRegister"/>

        <Region prefHeight="16"/>

        <!-- Lien vers connexion -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Déjà un compte ?" styleClass="link-text"/>
            <Hyperlink text="Se connecter"
                       styleClass="link-action"
                       onAction="#goToLogin"/>
        </HBox>

        <!-- Indicateur de chargement -->
        <ProgressIndicator fx:id="loadingIndicator"
                           visible="false"
                           managed="false"
                           styleClass="loading-spinner"
                           prefWidth="32"
                           prefHeight="32"/>

    </VBox>
</StackPane>
